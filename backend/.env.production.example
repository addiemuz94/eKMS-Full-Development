# Copy to .env.production on the VPS and fill in real secrets.
# Never commit .env.production.

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
DB_USER=ekms
DB_PASSWORD=replace-with-strong-db-password
DB_NAME=ekms

JWT_ACCESS_SECRET=replace-with-random-32plus-chars-access
JWT_REFRESH_SECRET=replace-with-random-32plus-chars-refresh
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

SUPER_ADMIN_EMAIL=admin@kms-cvt.com
SUPER_ADMIN_PASSWORD=replace-with-strong-admin-password
SUPER_ADMIN_DISPLAY_NAME=Super Admin

# Same-origin portal; keep these for safety if CORS is checked
CORS_ORIGINS=https://kms-cvt.com,https://www.kms-cvt.com
